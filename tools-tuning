#!/bin/sh

echo Stopping services ...
./stop-services

echo Cleaning up output directory ...
rm -rf function-270m

echo Running tools tuning ...
python instruction-tuning.py \
--epochs 2 \
--train-batch 1 \
--learning-rate 5e-6 \
--files tool/app-manager.train.hf.json,tool/home-automation.train.hf.json,tool/health.train.hf.json,tool/weather.train.hf.json,tool/user-profile.train.hf.json \
--tools tool/app-manager.tools.hf.json,tool/home-automation.tools.hf.json,tool/health.tools.hf.json,tool/weather.tools.hf.json,tool/user-profile.tools.hf.json \
--model /functiongemma-270m-it \
--output-dir function-270m \
--eval-steps 50 \
--save-steps 1000 \
--assert-max-length 

echo Starting services ...
./start-services
